<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <!-- Global settings -->
  <variable name="logDir" value="Logs" />
  <variable name="logTrace" value="Logs/Trace" />
  <variable name="logDebug" value="Logs/Debug" />
  <variable name="logInfo" value="Logs/Info" />
  <variable name="logWarn" value="Logs/Warn" />
  <variable name="logError" value="Logs/Error" />
  <variable name="logFatal" value="Logs/Fatal" />

  <targets>
    <!-- Console target -->
    <target name="console" xsi:type="Console"
            layout="${longdate} | ${level:uppercase=true} | ${logger} | ${message} ${exception}" />

    <!-- File targets per level -->
    <target name="traceFile" xsi:type="File"
            fileName="${logDir}/trace.log"
            layout="${longdate} | ${level} | ${logger} | ${message} ${exception}"
            archiveFileName="${logTrace}/trace-{#}.log"
            archiveNumbering="DateAndSequence"
            archiveDateFormat="yyyyMMdd"
            archiveEvery="Day"
            archiveAboveSize="10485760"
            maxArchiveDays="99" />

    <target name="debugFile" xsi:type="File"
            fileName="${logDir}/debug.log"
            layout="${longdate} | ${level} | ${logger} | ${message} ${exception}"
            archiveFileName="${logDebug}/debug-{#}.log"
            archiveNumbering="DateAndSequence"
            archiveDateFormat="yyyyMMdd"
            archiveEvery="Day"
            archiveAboveSize="10485760"
            maxArchiveDays="99" />

    <target name="infoFile" xsi:type="File"
            fileName="${logDir}/info.log"
            layout="${longdate} | ${level} | ${logger} | ${message} ${exception}"
            archiveFileName="${logInfo}/info-{#}.log"
            archiveNumbering="DateAndSequence"
            archiveDateFormat="yyyyMMdd"
            archiveEvery="Day"
            archiveAboveSize="10485760"
            maxArchiveDays="99" />

    <target name="warnFile" xsi:type="File"
            fileName="${logDir}/warn.log"
            layout="${longdate} | ${level} | ${logger} | ${message} ${exception}"
            archiveFileName="${logWarn}/warn-{#}.log"
            archiveNumbering="DateAndSequence"
            archiveDateFormat="yyyyMMdd"
            archiveEvery="Day"
            archiveAboveSize="10485760"
            maxArchiveDays="99" />

    <target name="errorFile" xsi:type="File"
            fileName="${logDir}/error.log"
            layout="${longdate} | ${level} | ${logger} | ${message} ${exception}"
            archiveFileName="${logError}/error-{#}.log"
            archiveNumbering="DateAndSequence"
            archiveDateFormat="yyyyMMdd"
            archiveEvery="Day"
            archiveAboveSize="10485760"
            maxArchiveDays="99" />

    <target name="fatalFile" xsi:type="File"
            fileName="${logDir}/fatal.log"
            layout="${longdate} | ${level} | ${logger} | ${message} ${exception}"
            archiveFileName="${logFatal}/fatal-{#}.log"
            archiveNumbering="DateAndSequence"
            archiveDateFormat="yyyyMMdd"
            archiveEvery="Day"
            archiveAboveSize="10485760"
            maxArchiveDays="99" />
  </targets>

  <rules>
    <!-- Console: show everything from Info and above -->
    <logger name="*" minlevel="Info" writeTo="console" />

    <!-- File rules: choose which levels go to which file -->
    <logger name="*" minlevel="Trace" maxlevel="Trace" writeTo="traceFile" />
    <logger name="*" minlevel="Debug" maxlevel="Debug" writeTo="debugFile" />
    <logger name="*" minlevel="Info"  maxlevel="Info"  writeTo="infoFile" />
    <logger name="*" minlevel="Warn"  maxlevel="Warn"  writeTo="warnFile" />
    <logger name="*" minlevel="Error" maxlevel="Error" writeTo="errorFile" />
    <logger name="*" minlevel="Fatal" maxlevel="Fatal" writeTo="fatalFile" />
 
  </rules>
</nlog>